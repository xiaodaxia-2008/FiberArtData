<?xml version='1.0' encoding='UTF-8'?>
<robot name="PositionerXS" payload="1000" brand="Custom" type="Positioner">
  <!-- Properties -->
  <!-- link list -->
  <material name="gray">
    <color rgba="0.4 0.4 0.4 1"/>
  </material>
  <link name="base_link">
    <visual>
      <geometry>
        <mesh filename="visual/base_link.stl"/>
      </geometry>
      <material name="gray"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="collision/base_link.stl"/>
      </geometry>
    </collision>
  </link>
  <link name="link1">
    <visual>
      <geometry>
        <mesh filename="visual/link1.stl"/>
      </geometry>
      <material name="gray"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="collision/link1.stl"/>
      </geometry>
    </collision>
  </link>
  <link name="ee_link"/>
  <!-- end of link list -->
  <!-- joint list -->
  <joint name="joint1" type="revolute">
    <parent link="base_link"/>
    <child link="link1"/>
    <origin xyz="0 0 0.6" rpy="0.0 0.0 0.0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-6.370452" upper="6.370452" velocity="6.283185"/>
  </joint>
  <joint name="joint_6_t-tool0" type="fixed">
    <origin xyz="0 0 0" rpy="0.0 0.0 0.0"/>
    <parent link="link1"/>
    <child link="ee_link"/>
  </joint>
  <!-- end of joint list -->
</robot>
