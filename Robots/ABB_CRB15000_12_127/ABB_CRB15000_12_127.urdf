  <!-- end of link list -->
  <!-- joint list -->
  <joint type="revolute" name="joint_1">
    <origin xyz="0 0 0.338" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <parent link="base_link"/>
    <child link="link_1"/>
    <limit effort="0" lower="${radians(-270)}" upper="${radians(270)}" velocity="${radians(120)}"/>
