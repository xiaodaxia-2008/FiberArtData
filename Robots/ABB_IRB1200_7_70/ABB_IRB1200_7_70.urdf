<?xml version="1.0" encoding="utf-8"?>
<robot name="ABB_IRB1200_7_70">
  <material name="abb_yellow">
    <color rgba="1 1 0 1"/>
  </material>
  <!-- link list -->
  <link name="base_link">
    <collision name="collision">
      <geometry>
        <mesh filename="collision/base_link.stl"/>
      </geometry>
    </collision>
    <visual name="visual">
      <geometry>
        <mesh filename="visual/base_link.dae"/>
      </geometry>
      <material name="abb_yellow"/>
    </visual>
  </link>
  <link name="link_1">
    <collision name="collision">
      <geometry>
        <mesh filename="collision/link_1.stl"/>
      </geometry>
    </collision>
    <visual name="visual">
      <geometry>
        <mesh filename="visual/link_1.dae"/>
      </geometry>
      <material name="abb_yellow"/>
    </visual>
  </link>
  <link name="link_2">
    <collision name="collision">
      <geometry>
        <mesh filename="collision/link_2.stl"/>
      </geometry>
    </collision>
    <visual name="visual">
      <geometry>
        <mesh filename="visual/link_2.dae"/>
      </geometry>
      <material name="abb_yellow"/>
    </visual>
  </link>
  <link name="link_3">
    <collision name="graphite_white">
      <geometry>
        <mesh filename="collision/link_3.stl"/>
      </geometry>
    </collision>
    <visual name="visual">
      <geometry>
        <mesh filename="visual/link_3.dae"/>
      </geometry>
      <material name="abb_yellow"/>
    </visual>
  </link>
  <link name="link_4">
    <collision name="collision">
      <!-- offset purely to allow reuse of meshes -->
      <origin xyz="-0.1 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="collision/link_4.stl"/>
      </geometry>
    </collision>
    <visual name="visual">
      <!-- offset purely to allow reuse of meshes -->
      <origin xyz="-0.1 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="visual/link_4.dae"/>
      </geometry>
      <material name="abb_yellow"/>
    </visual>
  </link>
  <link name="link_5">
    <collision name="collision">
      <geometry>
        <mesh filename="collision/link_5.stl"/>
      </geometry>
    </collision>
    <visual name="visual">
      <geometry>
        <mesh filename="visual/link_5.dae"/>
      </geometry>
      <material name="abb_yellow"/>
    </visual>
  </link>
  <link name="link_6">
    <collision name="collision">
      <geometry>
        <mesh filename="collision/link_6.stl"/>
      </geometry>
    </collision>
    <visual name="visual">
      <geometry>
        <mesh filename="visual/link_6.dae"/>
      </geometry>
      <material name="abb_yellow"/>
    </visual>
  </link>
  <!-- end of link list -->
  <!-- joint list -->
  <joint type="revolute" name="joint_1">
    <origin xyz="0 0 0.3991" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <parent link="base_link"/>
    <child link="link_1"/>
    <limit effort="0" lower="-2.967" upper="2.967" velocity="5.027"/>
  </joint>
  <joint type="revolute" name="joint_2">
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <parent link="link_1"/>
    <child link="link_2"/>
    <limit effort="0" lower="-1.745" upper="2.356" velocity="4.189"/>
  </joint>
  <joint type="revolute" name="joint_3">
    <origin xyz="0 0 0.350" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <parent link="link_2"/>
    <child link="link_3"/>
    <limit effort="0" lower="-3.491" upper="1.222" velocity="5.236"/>
  </joint>
  <joint type="revolute" name="joint_4">
    <origin xyz="0 0 0.042" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <parent link="link_3"/>
    <child link="link_4"/>
    <limit effort="0" lower="-4.712" upper="4.712" velocity="6.981"/>
  </joint>
  <joint type="revolute" name="joint_5">
    <origin xyz="0.351 0 0 " rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <parent link="link_4"/>
    <child link="link_5"/>
    <limit effort="0" lower="-2.269" upper="2.269" velocity="7.069"/>
  </joint>
  <joint type="revolute" name="joint_6">
    <origin xyz="0.082 0 0 " rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <parent link="link_5"/>
    <child link="link_6"/>
    <limit effort="0" lower="-6.283" upper="6.283" velocity="10.472"/>
  </joint>
  <!-- end of joint list -->
  <!-- ROS-Industrial 'base' frame: base_link to ABB World Coordinates transform -->
  <link name="base"/>
  <joint name="base_link-base" type="fixed">
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="base"/>
  </joint>
  <!-- ROS-Industrial 'flange' frame: attachment point for EEF models -->
  <link name="flange"/>
  <joint type="fixed" name="joint_6-flange">
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <parent link="link_6"/>
    <child link="flange"/>
  </joint>
  <!-- ROS-Industrial 'tool0' frame: all-zeros tool frame -->
  <link name="tool0"/>
  <joint name="link_6-tool0" type="fixed">
    <origin xyz="0 0 0" rpy="0 ${radians(90)} 0"/>
    <parent link="flange"/>
    <child link="tool0"/>
  </joint>
</robot>
