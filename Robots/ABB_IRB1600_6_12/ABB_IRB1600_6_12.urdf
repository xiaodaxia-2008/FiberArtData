<?xml version="1.0" encoding="utf-8"?>
<robot name="ABB_IRB1600_6_12" payload="6" reach="1.2" brand="ABB" type="Robot">
  <material name="abb_orange">
    <color rgba="0.7372549 0.3490196 0.1607843 1"/>
  </material>
  <material name="abb_yellow">
    <color rgba="1 1 0 1"/>
  </material>
  <!-- link list -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="visual/base_link.stl"/>
      </geometry>
      <material name="abb_orange"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="collision/base_link.stl"/>
      </geometry>
      <material name="abb_yellow"/>
    </collision>
  </link>
  <link name="link_1">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="visual/link_1.stl"/>
      </geometry>
      <material name="abb_orange"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="collision/link_1.stl"/>
      </geometry>
      <material name="abb_yellow"/>
    </collision>
  </link>
  <link name="link_2">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="visual/link_2.stl"/>
      </geometry>
      <material name="abb_orange"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="collision/link_2.stl"/>
      </geometry>
      <material name="abb_yellow"/>
    </collision>
  </link>
  <link name="link_3">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="visual/link_3.stl"/>
      </geometry>
      <material name="abb_orange"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="collision/link_3.stl"/>
      </geometry>
      <material name="abb_yellow"/>
    </collision>
  </link>
  <link name="link_4">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="visual/link_4.stl"/>
      </geometry>
      <material name="abb_orange"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="collision/link_4.stl"/>
      </geometry>
      <material name="abb_yellow"/>
    </collision>
  </link>
  <link name="link_5">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="visual/link_5.stl"/>
      </geometry>
      <material name="abb_orange"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="collision/link_5.stl"/>
      </geometry>
      <material name="abb_yellow"/>
    </collision>
  </link>
  <link name="link_6">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="visual/link_6.stl"/>
      </geometry>
      <material name="abb_orange"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="collision/link_6.stl"/>
      </geometry>
      <material name="abb_yellow"/>
    </collision>
  </link>
  <!-- end of link list -->
  <!-- joint list -->
  <joint name="joint_1" type="revolute">
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="link_1"/>
    <axis xyz="0 0 1"/>
    <limit lower="-${pi}" upper="${pi}" effort="0" velocity="2.618"/>
  </joint>
  <joint name="joint_2" type="revolute">
    <origin xyz="0.15 0 0.4865" rpy="0 0 0"/>
    <parent link="link_1"/>
    <child link="link_2"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.0995" upper="1.9198" effort="0" velocity="2.7925"/>
  </joint>
  <joint name="joint_3" type="revolute">
    <origin xyz="0 0 0.475" rpy="0 0 0"/>
    <parent link="link_2"/>
    <child link="link_3"/>
    <axis xyz="0 1 0"/>
    <limit lower="-4.1015" upper="0.9599" effort="0" velocity="2.9670"/>
  </joint>
  <joint name="joint_4" type="revolute">
    <origin xyz="0.300 0 0" rpy="0 0 0"/>
    <parent link="link_3"/>
    <child link="link_4"/>
    <axis xyz="1 0 0"/>
    <limit lower="-3.4906" upper="3.4906" effort="0" velocity="5.5850"/>
  </joint>
  <joint name="joint_5" type="revolute">
    <origin xyz="0.300 0 0" rpy="0 0 0"/>
    <parent link="link_4"/>
    <child link="link_5"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.0071" upper="2.0071" effort="0" velocity="6.9813"/>
  </joint>
  <joint name="joint_6" type="revolute">
    <origin xyz="0.065 0 0" rpy="0 0 0"/>
    <parent link="link_5"/>
    <child link="link_6"/>
    <axis xyz="1 0 0"/>
    <limit lower="-6.9813" upper="6.9813" effort="0" velocity="7.854"/>
  </joint>
  <!-- end of joint list -->
  <!-- ROS-Industrial 'base' frame: base_link to ABB World Coordinates transform -->
  <link name="base"/>
  <joint name="base_link-base" type="fixed">
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="base"/>
  </joint>
  <!-- ROS-Industrial 'flange' frame: attachment point for EEF models -->
  <link name="flange"/>
  <joint type="fixed" name="joint_6-flange">
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <parent link="link_6"/>
    <child link="flange"/>
  </joint>
  <!-- ROS-Industrial 'tool0' frame: all-zeros tool frame -->
  <link name="tool0"/>
  <joint name="link_6-tool0" type="fixed">
    <origin xyz="0 0 0" rpy="0 ${radians(90)} 0"/>
    <parent link="flange"/>
    <child link="tool0"/>
  </joint>
</robot>
