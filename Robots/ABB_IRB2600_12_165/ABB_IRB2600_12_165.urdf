  <link name="link_6">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="visual/link_6.stl"/>
      </geometry>
      <material name="">
        <color rgba="0.5 0.5 0.5 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="collision/link_6.stl"/>
      </geometry>
    </collision>
  </link>
  <!-- Joints -->
  <joint name="joint_1" type="revolute">
    <origin xyz="0 0 0.445" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="link_1"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14159" upper="3.14159" effort="0" velocity="3.054"/>
  </joint>
  <joint name="joint_2" type="revolute">
    <origin xyz="0.15 0 0.0" rpy="0 0 0"/>
    <parent link="link_1"/>
    <child link="link_2"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.705" upper="1.658" effort="0" velocity="3.054"/>
  </joint>
  <joint name="joint_3" type="revolute">
    <origin xyz="0 0 0.7" rpy="0 0 0"/>
    <parent link="link_2"/>
    <child link="link_3"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.705" upper="1.309" effort="0" velocity="3.054"/>
  </joint>
  <joint name="joint_4" type="revolute">
    <origin xyz="0 0 0.115" rpy="0 0 0"/>
    <parent link="link_3"/>
    <child link="link_4"/>
    <axis xyz="1 0 0"/>
    <limit lower="-6.981" upper="6.981" effort="0" velocity="6.283"/>
  </joint>
  <joint name="joint_5" type="revolute">
    <origin xyz="0.795 0 0 " rpy="0 0 0"/>
    <parent link="link_4"/>
    <child link="link_5"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.094" upper="2.094" effort="0" velocity="6.283"/>
  </joint>
  <joint name="joint_6" type="revolute">
    <origin xyz="0.085 0 0" rpy="0 0 0"/>
    <parent link="link_5"/>
    <child link="link_6"/>
    <axis xyz="1 0 0"/>
    <limit lower="-6.981" upper="6.981" effort="0" velocity="8.727"/>
  </joint>
  <!-- ROS-Industrial 'base' frame: base_link to ABB World Coordinates transform -->
  <link name="base"/>
  <joint name="base_link-base" type="fixed">
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="base"/>
  </joint>
  <!-- ROS-Industrial 'flange' frame: attachment point for EEF models -->
  <link name="flange"/>
  <joint type="fixed" name="joint_6-flange">
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <parent link="link_6"/>
    <child link="flange"/>
  </joint>
  <!-- ROS-Industrial 'tool0' frame: all-zeros tool frame -->
  <link name="tool0"/>
  <joint name="link_6-tool0" type="fixed">
    <origin xyz="0 0 0" rpy="0 ${radians(90)} 0"/>
    <parent link="flange"/>
    <child link="tool0"/>
  </joint>
</robot>
