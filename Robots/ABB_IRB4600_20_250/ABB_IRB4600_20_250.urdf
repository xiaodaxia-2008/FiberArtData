<?xml version="1.0" encoding="utf-8"?>
<robot name="ABB_IRB4600_20_250">
  <material name="abb_white">
    <color rgba="0.9254902 0.9254902 0.9058824 1"/>
  </material>
  <material name="yellow">
    <color rgba="1 1 0 1"/>
  </material>
  <!-- link list -->
  <link name="base_link">
    <collision name="collision">
      <geometry>
        <mesh filename="collision/base_link.stl"/>
      </geometry>
      <material name="abb_white"/>
    </collision>
    <visual name="visual">
      <geometry>
        <mesh filename="visual/base_link.dae"/>
      </geometry>
      <material name="abb_white"/>
      <material name="yellow">
        <color rgba="1 1 0 1"/>
      </material>
    </visual>
  </link>
  <link name="link_1">
    <collision name="collision">
      <geometry>
        <mesh filename="collision/link_1.stl"/>
      </geometry>
      <material name="abb_white"/>
    </collision>
    <visual name="visual">
      <geometry>
        <mesh filename="visual/link_1.dae"/>
      </geometry>
      <material name="abb_white"/>
      <material name="yellow"/>
    </visual>
  </link>
  <link name="link_2">
    <collision name="collision">
      <geometry>
        <mesh filename="collision/link_2.stl"/>
      </geometry>
      <material name="abb_white"/>
    </collision>
    <visual name="visual">
      <geometry>
        <mesh filename="visual/link_2.dae"/>
      </geometry>
      <material name="abb_white"/>
      <material name="yellow"/>
    </visual>
  </link>
  <link name="link_3">
    <collision name="collision">
      <geometry>
        <mesh filename="collision/link_3.stl"/>
      </geometry>
      <material name="abb_white"/>
    </collision>
    <visual name="visual">
      <geometry>
        <mesh filename="visual/link_3.dae"/>
      </geometry>
      <material name="abb_white"/>
      <material name="yellow"/>
    </visual>
  </link>
  <link name="link_4">
    <collision name="collision">
      <geometry>
        <mesh filename="collision/link_4.stl"/>
      </geometry>
      <material name="abb_white"/>
    </collision>
    <visual name="visual">
      <geometry>
        <mesh filename="visual/link_4.dae"/>
      </geometry>
      <material name="abb_white"/>
      <material name="yellow"/>
    </visual>
  </link>
  <link name="link_5">
    <collision name="collision">
      <geometry>
        <mesh filename="collision/link_5.stl"/>
      </geometry>
      <material name="abb_white"/>
    </collision>
    <visual name="visual">
      <geometry>
        <mesh filename="visual/link_5.dae"/>
      </geometry>
      <material name="abb_white"/>
      <material name="yellow"/>
    </visual>
  </link>
  <link name="link_6">
    <collision name="collision">
      <geometry>
        <mesh filename="collision/link_6.stl"/>
      </geometry>
      <material name="abb_white"/>
    </collision>
    <visual name="visual">
      <geometry>
        <mesh filename="visual/link_6.dae"/>
      </geometry>
      <material name="abb_white"/>
      <material name="yellow"/>
    </visual>
  </link>
  <!-- end of link list -->
  <!-- joint list -->
  <joint type="revolute" name="joint_1">
    <origin xyz="0 0 0.495" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <parent link="base_link"/>
    <child link="link_1"/>
    <limit effort="0" lower="${radians(-180)}" upper="${radians(180)}" velocity="${radians(175)}"/>
  </joint>
  <joint type="revolute" name="joint_2">
    <origin xyz="0.175 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <parent link="link_1"/>
    <child link="link_2"/>
    <limit effort="0" lower="${radians(-90)}" upper="${radians(150)}" velocity="${radians(175)}"/>
  </joint>
  <joint type="revolute" name="joint_3">
    <origin xyz="0 0 1.095" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <parent link="link_2"/>
    <child link="link_3"/>
    <limit effort="0" lower="${radians(-180)}" upper="${radians(75)}" velocity="${radians(175)}"/>
  </joint>
  <joint type="revolute" name="joint_4">
    <origin xyz="0 0 0.175" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <parent link="link_3"/>
    <child link="link_4"/>
    <limit effort="0" lower="${radians(-400)}" upper="${radians(400)}" velocity="${radians(360)}"/>
  </joint>
  <joint type="revolute" name="joint_5">
    <origin xyz="1.2305 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <parent link="link_4"/>
    <child link="link_5"/>
    <limit effort="0" lower="${radians(-125)}" upper="${radians(120)}" velocity="${radians(360)}"/>
  </joint>
  <joint type="revolute" name="joint_6">
    <origin xyz="0.085 0 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <parent link="link_5"/>
    <child link="link_6"/>
    <limit effort="0" lower="${radians(-400)}" upper="${radians(400)}" velocity="${radians(500)}"/>
  </joint>
  <!-- end of joint list -->
  <!-- ROS-Industrial 'base' frame: base_link to ABB World Coordinates transform -->
  <link name="base"/>
  <joint name="base_link-base" type="fixed">
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="base"/>
  </joint>
  <!-- ROS-Industrial 'flange' frame: attachment point for EEF models -->
  <link name="flange"/>
  <joint type="fixed" name="joint_6-flange">
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <parent link="link_6"/>
    <child link="flange"/>
  </joint>
  <!-- ROS-Industrial 'tool0' frame: all-zeros tool frame -->
  <link name="tool0"/>
  <joint name="link_6-tool0" type="fixed">
    <origin xyz="0 0 0" rpy="0 ${radians(90)} 0"/>
    <parent link="flange"/>
    <child link="tool0"/>
  </joint>
</robot>
