<?xml version="1.0" encoding="utf-8"?>
<robot name="ABB_IRB6700_200_260" payload="200" reach="2.6" brand="ABB" type="Robot">
  <material name="abb_white">
    <color rgba="0.9254902 0.9254902 0.9058824 1"/>
  </material>
  <material name="abb_yellow">
    <color rgba="1 1 0 1"/>
  </material>
  <!-- link list -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="visual/base_link.stl"/>
      </geometry>
      <material name="abb_white"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="collision/base_link.stl"/>
      </geometry>
      <material name="abb_yellow"/>
    </collision>
  </link>
  <link name="link_1">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="visual/link_1.stl"/>
      </geometry>
      <material name="abb_white"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="collision/link_1.stl"/>
      </geometry>
      <material name="abb_yellow"/>
    </collision>
  </link>
  <link name="cylinder">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="visual/cylinder.stl"/>
      </geometry>
      <material name="abb_white"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="collision/cylinder.stl"/>
      </geometry>
      <material name="abb_yellow"/>
    </collision>
  </link>
  <link name="piston">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="visual/piston.stl"/>
      </geometry>
      <material name="abb_white"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="collision/piston.stl"/>
      </geometry>
      <material name="abb_yellow"/>
    </collision>
  </link>
  <link name="link_2">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="visual/link_2.stl"/>
      </geometry>
      <material name="abb_white"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="collision/link_2.stl"/>
      </geometry>
      <material name="abb_yellow"/>
    </collision>
  </link>
  <link name="link_3">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="visual/link_3.stl"/>
      </geometry>
      <material name="abb_white"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="collision/link_3.stl"/>
      </geometry>
      <material name="abb_yellow"/>
    </collision>
  </link>
  <link name="link_4">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="visual/link_4.stl"/>
      </geometry>
      <material name="abb_white"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="collision/link_4.stl"/>
      </geometry>
      <material name="abb_yellow"/>
    </collision>
  </link>
  <link name="link_5">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="visual/link_5.stl"/>
      </geometry>
      <material name="abb_white"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="collision/link_5.stl"/>
      </geometry>
      <material name="abb_yellow"/>
    </collision>
  </link>
  <link name="link_6">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="visual/link_6.stl"/>
      </geometry>
      <material name="abb_white"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="collision/link_6.stl"/>
      </geometry>
      <material name="abb_yellow"/>
    </collision>
  </link>
  <joint name="joint_1" type="revolute">
    <origin xyz="0 0 0.78" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="link_1"/>
    <axis xyz="0 0 1"/>
    <limit lower="-${radians(170)}" upper="${radians(170)}" effort="0" velocity="${radians(110)}"/>
  </joint>
  <joint name="joint_2" type="revolute">
    <origin xyz="0.32 0 0" rpy="0 0 0"/>
    <parent link="link_1"/>
    <child link="link_2"/>
    <axis xyz="0 1 0"/>
    <limit lower="-${radians(65)}" upper="${radians(85)}" effort="0" velocity="${radians(110)}"/>
  </joint>
  <joint name="joint_3" type="revolute">
    <origin xyz="0 0 1.125" rpy="0 0 0"/>
    <parent link="link_2"/>
    <child link="link_3"/>
    <axis xyz="0 1 0"/>
    <limit lower="-${radians(180)}" upper="${radians(70)}" effort="0" velocity="${radians(110)}"/>
  </joint>
  <joint name="joint_4" type="revolute">
    <origin xyz="0 0 0.2" rpy="0 0 0"/>
    <parent link="link_3"/>
    <child link="link_4"/>
    <axis xyz="1 0 0"/>
    <limit lower="-${radians(300)}" upper="${radians(300)}" effort="0" velocity="${radians(190)}"/>
  </joint>
  <joint name="joint_5" type="revolute">
    <origin xyz="1.1425 0 0" rpy="0 0 0"/>
    <parent link="link_4"/>
    <child link="link_5"/>
    <axis xyz="0 1 0"/>
    <limit lower="-${radians(130)}" upper="${radians(130)}" effort="0" velocity="${radians(150)}"/>
  </joint>
  <joint name="joint_6" type="revolute">
    <origin xyz="0.2 0 0" rpy="0 0 0"/>
    <parent link="link_5"/>
    <child link="link_6"/>
    <axis xyz="1 0 0"/>
    <limit lower="-${radians(360)}" upper="${radians(360)}" effort="0" velocity="${radians(210)}"/>
  </joint>
  <joint name="cylinder_joint" type="revolute">
    <origin xyz="-0.349 -0.194 -0.142" rpy="0 0 0"/>
    <parent link="link_1"/>
    <child link="cylinder"/>
    <axis xyz="0 1 0"/>
    <mimic joint="joint_2" multiplier="-0.25"/>
    <limit lower="-${radians(65*0.25)}" upper="${radians(85*0.25)}" effort="0" velocity="100"/>
  </joint>
  <joint name="piston_joint" type="prismatic">
    <origin xyz="0 0 0" rpy="0.20897 0 -${radians(90)}"/>
    <parent link="cylinder"/>
    <child link="piston"/>
    <axis xyz="0 1 0"/>
    <mimic joint="joint_2" multiplier="0.15"/>
    <limit lower="-0.25" upper="0.25" effort="0" velocity="100"/>
  </joint>
  <!-- ROS-Industrial 'base' frame: base_link to ABB World Coordinates transform -->
  <link name="base"/>
  <joint name="base_link-base" type="fixed">
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="base"/>
  </joint>
  <!-- ROS-Industrial 'flange' frame: attachment point for EEF models -->
  <link name="flange"/>
  <joint type="fixed" name="joint_6-flange">
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <parent link="link_6"/>
    <child link="flange"/>
  </joint>
  <!-- ROS-Industrial 'tool0' frame: all-zeros tool frame -->
  <link name="tool0"/>
  <joint name="link_6-tool0" type="fixed">
    <origin xyz="0 0 0" rpy="0 ${radians(90)} 0"/>
    <parent link="flange"/>
    <child link="tool0"/>
  </joint>
</robot>
