<?xml version="1.0" encoding="utf-8"?>
<robot name="ABB_IRB7600_150_350">
  <material name="abb_black">
    <color rgba="0.1882353 0.1960784 0.2039216 1"/>
  </material>
  <material name="abb_orange">
    <color rgba="0.7372549 0.3490196 0.1607843 1"/>
  </material>
  <material name="abb_yellow">
    <color rgba="1 1 0 1"/>
  </material>
  <!-- link list -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="visual/base_link.stl"/>
      </geometry>
      <material name="abb_orange"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="collision/base_link.stl"/>
      </geometry>
      <material name="abb_orange"/>
    </collision>
  </link>
  <link name="link_1">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="visual/link_1.stl"/>
      </geometry>
      <material name="abb_orange"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="collision/link_1.stl"/>
      </geometry>
      <material name="abb_yellow"/>
    </collision>
  </link>
  <link name="link_2">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="visual/link_2.stl"/>
      </geometry>
      <material name="abb_orange"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="collision/link_2.stl"/>
      </geometry>
      <material name="abb_yellow"/>
    </collision>
  </link>
  <link name="link_3">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="visual/link_3.stl"/>
      </geometry>
      <material name="abb_orange"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="collision/link_3.stl"/>
      </geometry>
      <material name="abb_yellow"/>
    </collision>
  </link>
  <link name="link_4">
    <visual>
      <origin xyz="2.012 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="visual/link_4.stl"/>
      </geometry>
      <material name="abb_orange"/>
    </visual>
    <visual>
      <origin xyz="2.012 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="visual/abb_logos.stl"/>
      </geometry>
      <material name="abb_black"/>
    </visual>
    <collision>
      <origin xyz="2.012 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="collision/link_4.stl"/>
      </geometry>
      <material name="abb_yellow"/>
    </collision>
  </link>
  <link name="link_5">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="visual/link_5.stl"/>
      </geometry>
      <material name="abb_orange"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="collision/link_5.stl"/>
      </geometry>
      <material name="abb_yellow"/>
    </collision>
  </link>
  <link name="link_6">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="visual/link_6.stl"/>
      </geometry>
      <material name="abb_black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="collision/link_6.stl"/>
      </geometry>
      <material name="abb_black"/>
    </collision>
  </link>
  <link name="balancer_piston">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="visual/balancer_piston.stl"/>
      </geometry>
      <material name="abb_orange"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="collision/balancer_piston.stl"/>
      </geometry>
      <material name="abb_yellow"/>
    </collision>
  </link>
  <!-- end of link list -->
  <!-- joint list -->
  <joint name="joint_1" type="revolute">
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="link_1"/>
    <axis xyz="0 0 1"/>
    <limit lower="-${radians(180)}" upper="${radians(180)}" effort="0" velocity="${radians(100)}"/>
  </joint>
  <joint name="joint_2" type="revolute">
    <origin xyz="0.410 0 0.780" rpy="0 0 0"/>
    <parent link="link_1"/>
    <child link="link_2"/>
    <axis xyz="0 1 0"/>
    <limit lower="-${radians(60)}" upper="${radians(85)}" effort="0" velocity="${radians(60)}"/>
  </joint>
  <joint name="joint_3" type="revolute">
    <origin xyz="0 0 1.075" rpy="0 0 0"/>
    <parent link="link_2"/>
    <child link="link_3"/>
    <axis xyz="0 1 0"/>
    <limit lower="-${radians(180)}" upper="${radians(60)}" effort="0" velocity="${radians(60)}"/>
  </joint>
  <joint name="joint_4" type="revolute">
    <origin xyz="0 0 0.165" rpy="0 0 0"/>
    <parent link="link_3"/>
    <child link="link_4"/>
    <axis xyz="1 0 0"/>
    <limit lower="-${radians(300)}" upper="${radians(300)}" effort="0" velocity="${radians(100)}"/>
  </joint>
  <joint name="joint_5" type="revolute">
    <origin xyz="2.012 0 0" rpy="0 0 0"/>
    <parent link="link_4"/>
    <child link="link_5"/>
    <axis xyz="0 1 0"/>
    <limit lower="-${radians(100)}" upper="${radians(100)}" effort="0" velocity="${radians(100)}"/>
  </joint>
  <joint name="joint_6" type="revolute">
    <origin xyz="0.250 0 0" rpy="0 0 0"/>
    <parent link="link_5"/>
    <child link="link_6"/>
    <axis xyz="1 0 0"/>
    <limit lower="-${radians(360)}" upper="${radians(360)}" effort="0" velocity="${radians(190)}"/>
  </joint>
  <joint name="joint_balancer_piston" type="fixed">
    <origin xyz="-0.380 0 0.6545" rpy="0 0 0"/>
    <parent link="link_1"/>
    <child link="balancer_piston"/>
  </joint>
  <!-- end of joint list -->
  <!-- ROS-Industrial 'base' frame: base_link to ABB World Coordinates transform -->
  <link name="base"/>
  <joint name="base_link-base" type="fixed">
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="base"/>
  </joint>
  <!-- ROS-Industrial 'flange' frame: attachment point for EEF models -->
  <link name="flange"/>
  <joint type="fixed" name="joint_6-flange">
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <parent link="link_6"/>
    <child link="flange"/>
  </joint>
  <!-- ROS-Industrial 'tool0' frame: all-zeros tool frame -->
  <link name="tool0"/>
  <joint name="link_6-tool0" type="fixed">
    <origin xyz="0 0 0" rpy="0 ${radians(90)} 0"/>
    <parent link="flange"/>
    <child link="tool0"/>
  </joint>
</robot>
