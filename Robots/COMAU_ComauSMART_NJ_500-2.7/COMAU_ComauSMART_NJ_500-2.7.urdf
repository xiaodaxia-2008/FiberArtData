<?xml version="1.0" encoding="utf-8"?>
<robot name="COMAU_ComauSMART_NJ_500-2.7" payload="500" reach="2.703" brand="COMAU" type="Robot">
  <!-- Properties -->
  <material name="gray">
    <color rgba="0.4 0.4 0.4 1"/>
  </material>
  <material name="comau_red">
    <color rgba="0.84 0 0 1"/>
  </material>
  <!-- link list -->
  <link name="base_link">
    <visual>
      <geometry>
        <mesh filename="visual/base_link.stl"/>
      </geometry>
      <material name="gray"/>
    </visual>
    <collision name="collision">
      <geometry>
        <mesh filename="collision/base_link.stl"/>
      </geometry>
    </collision>
  </link>
  <link name="link1">
    <visual>
      <geometry>
        <mesh filename="visual/link_1.stl"/>
      </geometry>
      <material name="comau_red"/>
    </visual>
    <collision name="collision">
      <geometry>
        <mesh filename="collision/link1.stl"/>
      </geometry>
    </collision>
  </link>
  <link name="link2">
    <visual>
      <geometry>
        <mesh filename="visual/link_2.stl"/>
      </geometry>
      <material name="comau_red"/>
    </visual>
    <collision name="collision">
      <geometry>
        <mesh filename="collision/link2.stl"/>
      </geometry>
    </collision>
  </link>
  <link name="link3">
    <visual>
      <geometry>
        <mesh filename="visual/link_3.stl"/>
      </geometry>
      <material name="comau_red"/>
    </visual>
    <collision name="collision">
      <geometry>
        <mesh filename="collision/link3.stl"/>
      </geometry>
    </collision>
  </link>
  <link name="link4">
    <visual>
      <geometry>
        <mesh filename="visual/link_4.stl"/>
      </geometry>
      <material name="comau_red"/>
    </visual>
    <collision name="collision">
      <geometry>
        <mesh filename="collision/link4.stl"/>
      </geometry>
    </collision>
  </link>
  <link name="link5">
    <visual>
      <geometry>
        <mesh filename="visual/link_5.stl"/>
      </geometry>
      <material name="comau_red"/>
    </visual>
    <collision name="collision">
      <geometry>
        <mesh filename="collision/link5.stl"/>
      </geometry>
    </collision>
  </link>
  <link name="link6">
    <visual>
      <geometry>
        <mesh filename="visual/link_6.stl"/>
      </geometry>
      <material name="comau_red"/>
    </visual>
    <collision name="collision">
      <geometry>
        <mesh filename="collision/link6.stl"/>
      </geometry>
    </collision>
  </link>
  <link name="ee_link"/>
  <!-- end of link list -->
  <!-- joint list -->
  <joint name="joint1" type="revolute">
    <parent link="base_link"/>
    <child link="link1"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 -1"/>
    <limit lower="${radians(-180)}" upper="${radians(180)}" velocity="${radians(45)}"/>
  </joint>
  <joint name="joint2" type="revolute">
    <parent link="link1"/>
    <child link="link2"/>
    <origin xyz="0.46 0 1.14" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="${radians(-60)}" upper="${radians(75)}" velocity="${radians(45)}"/>
  </joint>
  <joint name="joint3" type="revolute">
    <parent link="link2"/>
    <child link="link3"/>
    <origin xyz="0 0 1.05" rpy="0 ${radians(-90)} 0"/>
    <axis xyz="0 -1 0"/>
    <limit lower="${radians(-231)}" upper="${radians(-10)}" velocity="${radians(45)}"/>
  </joint>
  <joint name="joint4" type="revolute">
    <parent link="link3"/>
    <child link="link4"/>
    <origin xyz="1.205 0 0.25" rpy="0 0 0"/>
    <axis xyz="-1 0 0"/>
    <limit lower="${radians(-2700)}" upper="${radians(2700)}" velocity="${radians(90)}"/>
  </joint>
  <joint name="joint5" type="revolute">
    <parent link="link4"/>
    <child link="link5"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="${radians(-125)}" upper="${radians(125)}" velocity="${radians(83)}"/>
  </joint>
  <joint name="joint6" type="revolute">
    <parent link="link5"/>
    <child link="link6"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="-1 0 0"/>
    <limit lower="${radians(-2700)}" upper="${radians(2700)}" velocity="${radians(130)}"/>
  </joint>
  <joint name="joint_6_t-tool0" type="fixed">
    <origin xyz="0.282 0 0" rpy="0 ${radians(90)} 0"/>
    <parent link="link6"/>
    <child link="ee_link"/>
  </joint>
  <!-- end of joint list -->
  <tcp xyz="0 0 0" rpy="0 0 0"/>
  <!-- home positions  -->
  <home_positions joints="0 0 ${radians(-90)} 0 ${radians(90)} 0"/>
  <!-- Ortho-parallel Basis and a Spherical Wrist -->
  <opw_parameters>
    <c1>1.14</c1>
    <c2>1.05</c2>
    <c3>1.205</c3>
    <c4>0.282</c4>
    <a1>0.46</a1>
    <a2>-0.25</a2>
    <b>0</b>
    <joint1 sign_correction="-1" offset="0"/>
    <joint2 sign_correction="1" offset="0"/>
    <joint3 sign_correction="-1" offset="0"/>
    <joint4 sign_correction="-1" offset="0"/>
    <joint5 sign_correction="1" offset="0"/>
    <joint6 sign_correction="-1" offset="0"/>
  </opw_parameters>
</robot>
