<?xml version="1.0" encoding="utf-8"?>
<robot name="FANUC_CRX10IAL">
  <material name="fanuc_gray24">
    <color rgba="0.239216 0.239216 0.239216 1.0"/>
  </material>
  <material name="fanuc_white">
    <color rgba="0.86 0.85 0.81 1.0"/>
  </material>
  <!-- links: main serial chain -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="visual/base_link.stl"/>
      </geometry>
      <material name="fanuc_gray24"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="collision/base_link.stl"/>
      </geometry>
    </collision>
  </link>
  <link name="link_1">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="visual/link_1.stl"/>
      </geometry>
      <material name="fanuc_white"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="collision/link_1.stl"/>
      </geometry>
    </collision>
  </link>
  <link name="link_2">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="visual/link_2.stl"/>
      </geometry>
      <material name="fanuc_white"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="collision/link_2.stl"/>
      </geometry>
    </collision>
  </link>
  <link name="link_3">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="visual/link_3.stl"/>
      </geometry>
      <material name="fanuc_white"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="collision/link_3.stl"/>
      </geometry>
    </collision>
  </link>
  <link name="link_4">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="visual/link_4.stl"/>
      </geometry>
      <material name="fanuc_white"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="collision/link_4.stl"/>
      </geometry>
    </collision>
  </link>
  <link name="link_5">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="visual/link_5.stl"/>
      </geometry>
      <material name="fanuc_white"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="collision/link_5.stl"/>
      </geometry>
    </collision>
  </link>
  <link name="link_6">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="visual/link_6.stl"/>
      </geometry>
      <material name="fanuc_gray24"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="collision/link_6.stl"/>
      </geometry>
    </collision>
  </link>
  <!-- joints: main serial chain -->
  <joint name="joint_1" type="revolute">
    <origin xyz="0 0 0.245" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="link_1"/>
    <axis xyz="0 0 1"/>
    <limit effort="0" lower="${radians(-180)}" upper="${radians(180)}" velocity="${radians(120)}"/>
  </joint>
  <joint name="joint_2" type="revolute">
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <parent link="link_1"/>
    <child link="link_2"/>
    <axis xyz="0 1 0"/>
    <limit effort="0" lower="${radians(-180)}" upper="${radians(180)}" velocity="${radians(120)}"/>
  </joint>
  <joint name="joint_3" type="revolute">
    <origin xyz="0 0 0.710" rpy="0 0 0"/>
    <parent link="link_2"/>
    <child link="link_3"/>
    <axis xyz="0 -1 0"/>
    <limit effort="0" lower="${radians(-270)}" upper="${radians(270)}" velocity="${radians(180)}"/>
  </joint>
  <joint name="joint_4" type="revolute">
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <parent link="link_3"/>
    <child link="link_4"/>
    <axis xyz="-1 0 0"/>
    <limit effort="0" lower="${radians(-190)}" upper="${radians(190)}" velocity="${radians(180)}"/>
  </joint>
  <joint name="joint_5" type="revolute">
    <origin xyz="0.540 -0.150 0" rpy="0 0 0"/>
    <parent link="link_4"/>
    <child link="link_5"/>
    <axis xyz="0 -1 0"/>
    <limit effort="0" lower="${radians(-180)}" upper="${radians(180)}" velocity="${radians(180)}"/>
  </joint>
  <joint name="joint_6" type="revolute">
    <origin xyz="0.160 0 0" rpy="0 0 0"/>
    <parent link="link_5"/>
    <child link="link_6"/>
    <axis xyz="-1 0 0"/>
    <limit effort="0" lower="${radians(-190)}" upper="${radians(190)}" velocity="${radians(180)}"/>
  </joint>
  <!-- ROS-Industrial 'base' frame: base_link to Fanuc World Coordinates transform -->
  <link name="base"/>
  <joint name="base_link-base" type="fixed">
    <origin xyz="0 0 0.245" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="base"/>
  </joint>
  <!-- ROS-Industrial 'flange' frame: attachment point for EEF models -->
  <link name="flange"/>
  <joint name="joint_6-flange" type="fixed">
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <parent link="link_6"/>
    <child link="flange"/>
  </joint>
  <!-- ROS-Industrial 'tool0' frame: all-zeros tool frame -->
  <link name="tool0"/>
  <joint name="link_6-tool0" type="fixed">
    <origin xyz="0 0 0" rpy="${pi} ${-pi/2.0} 0"/>
    <parent link="flange"/>
    <child link="tool0"/>
  </joint>
</robot>
