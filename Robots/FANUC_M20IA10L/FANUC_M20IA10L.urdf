  <link name="link_6">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="visual/link_6.stl"/>
      </geometry>
      <material name="fanuc_black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="collision/link_6.stl"/>
      </geometry>
    </collision>
  </link>
  <!-- joints: main serial chain -->
  <joint name="joint_1" type="revolute">
    <origin xyz="0 0 0.525" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="link_1"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.228859" upper="3.228859" effort="0" velocity="3.403392"/>
  </joint>
  <joint name="joint_2" type="revolute">
    <origin xyz="0.150 0 0" rpy="0 0 0"/>
    <parent link="link_1"/>
    <child link="link_2"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.745329" upper="2.792527" effort="0" velocity="3.054326"/>
  </joint>
  <joint name="joint_3" type="revolute">
    <origin xyz="0 0 0.790" rpy="0 0 0"/>
    <parent link="link_2"/>
    <child link="link_3"/>
    <axis xyz="0 -1 0"/>
    <limit lower="-3.228859" upper="4.810826" effort="0" velocity="3.141593"/>
  </joint>
  <joint name="joint_4" type="revolute">
    <origin xyz="0 0 0.250" rpy="0 0 0"/>
    <parent link="link_3"/>
    <child link="link_4"/>
    <axis xyz="-1 0 0"/>
    <limit lower="-3.490658" upper="3.490658" effort="0" velocity="6.981317"/>
  </joint>
  <joint name="joint_5" type="revolute">
    <origin xyz="1.040 0 0" rpy="0 0 0"/>
    <parent link="link_4"/>
    <child link="link_5"/>
    <axis xyz="0 -1 0"/>
    <limit lower="-2.443461" upper="2.443461" effort="0" velocity="6.981317"/>
  </joint>
  <joint name="joint_6" type="revolute">
    <origin xyz="0.100 0 0" rpy="0 0 0"/>
    <parent link="link_5"/>
    <child link="link_6"/>
    <axis xyz="-1 0 0"/>
    <limit lower="-4.712389" upper="4.712389" effort="0" velocity="10.471980"/>
  </joint>
  <!-- ROS-Industrial 'base' frame: base_link to Fanuc World Coordinates transform -->
  <link name="base"/>
  <joint name="base_link-base" type="fixed">
    <origin xyz="0 0 0.525" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="base"/>
  </joint>
  <!-- ROS-Industrial 'flange' frame: attachment point for EEF models -->
  <link name="flange"/>
  <joint name="joint_6-flange" type="fixed">
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <parent link="link_6"/>
    <child link="flange"/>
  </joint>
  <!-- ROS-Industrial 'tool0' frame: all-zeros tool frame -->
  <link name="tool0"/>
  <joint name="link_6-tool0" type="fixed">
    <origin xyz="0 0 0" rpy="${pi} ${-pi/2.0} 0"/>
    <parent link="flange"/>
    <child link="tool0"/>
  </joint>
</robot>
