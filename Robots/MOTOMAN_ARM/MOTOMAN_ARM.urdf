<?xml version='1.0' encoding='utf-8'?>
<robot name="MOTOMAN_ARM" brand="MOTOMAN" type="Robot" payload="10" reach="0.72">
  <material name="yaskawa_blue">
    <color rgba="0.1294118 0.1490196 0.7490196 1.0"/>
  </material>
  <material name="yaskawa_white">
    <color rgba="0.99 0.99 0.99 1"/>
  </material>
  <link name="link_1_s">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="visual/link_s.stl"/>
      </geometry>
      <material name="yaskawa_blue"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="collision/link_s.stl"/>
      </geometry>
    </collision>
  </link>
  <link name="link_2_l">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="visual/link_l.stl"/>
      </geometry>
      <material name="yaskawa_white"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="collision/link_l.stl"/>
      </geometry>
    </collision>
  </link>
  <link name="link_3_e">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="visual/link_e.stl"/>
      </geometry>
      <material name="yaskawa_blue"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="collision/link_e.stl"/>
      </geometry>
    </collision>
  </link>
  <link name="link_4_u">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="visual/link_u.stl"/>
      </geometry>
      <material name="yaskawa_white"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="collision/link_u.stl"/>
      </geometry>
    </collision>
  </link>
  <link name="link_5_r">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="visual/link_r.stl"/>
      </geometry>
      <material name="yaskawa_blue"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="collision/link_r.stl"/>
      </geometry>
    </collision>
  </link>
  <link name="link_6_b">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="visual/link_b.stl"/>
      </geometry>
      <material name="yaskawa_white"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="collision/link_b.stl"/>
      </geometry>
    </collision>
  </link>
  <link name="link_7_t">
    <visual>
      <geometry>
        <mesh filename="visual/link_t.stl"/>
      </geometry>
      <material name="yaskawa_blue"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="collision/link_t.stl"/>
      </geometry>
    </collision>
  </link>
  <link name="link_tool0"/>
  <joint name="joint_1_s" type="revolute">
    <parent link="${parent}"/>
    <child link="link_1_s"/>
    <origin xyz="0.100 ${reflect*0.265} 0.0" rpy="${radians(90)} 0.0 ${(reflect-1)*radians(90)}"/>
    <axis xyz="0 0 ${-reflect}"/>
    <limit lower="${radians(-180)}" upper="${radians(180)}" effort="0" velocity="${radians(170)}"/>
  </joint>
  <joint name="joint_2_l" type="revolute">
    <parent link="link_1_s"/>
    <child link="link_2_l"/>
    <origin xyz="0.0 0.0 0.0" rpy="${radians(-90)} 0.0 0.0"/>
    <axis xyz="0 0 ${-reflect}"/>
    <limit lower="${radians(-110)}" upper="${radians(110)}" effort="0" velocity="${radians(170)}"/>
  </joint>
  <joint name="joint_3_e" type="revolute">
    <parent link="link_2_l"/>
    <child link="link_3_e"/>
    <origin xyz="0.0 0.360 0.0" rpy="${radians(90)} 0.0 0.0"/>
    <axis xyz="0 0 ${-reflect}"/>
    <limit lower="${radians(-170)}" upper="${radians(170)}" effort="0" velocity="${radians(170)}"/>
  </joint>
  <joint name="joint_4_u" type="revolute">
    <parent link="link_3_e"/>
    <child link="link_4_u"/>
    <origin xyz="0.0 0.0 0.0" rpy="${radians(-90)} 0.0 0.0"/>
    <axis xyz="0 0 ${reflect}"/>
    <limit lower="${radians(-135)}" upper="${radians(135)}" effort="0" velocity="${radians(170)}"/>
  </joint>
  <joint name="joint_5_r" type="revolute">
    <parent link="link_4_u"/>
    <child link="link_5_r"/>
    <origin xyz="0.0 0.360 0.0" rpy="${radians(90)} 0.0 0.0"/>
    <axis xyz="0 0 ${reflect}"/>
    <limit lower="${radians(-180)}" upper="${radians(180)}" effort="0" velocity="${radians(200)}"/>
  </joint>
  <joint name="joint_6_b" type="revolute">
    <parent link="link_5_r"/>
    <child link="link_6_b"/>
    <origin xyz="0.0 0.0 0.0" rpy="${radians(-90)} 0.0 0.0"/>
    <axis xyz="0 0 ${reflect}"/>
    <limit lower="${radians(-110)}" upper="${radians(110)}" effort="0" velocity="${radians(200)}"/>
  </joint>
  <joint name="joint_7_t" type="revolute">
    <parent link="link_6_b"/>
    <child link="link_7_t"/>
    <origin xyz="0.0 0.155 0.0" rpy="${radians(-90)} 0.0 0.0"/>
    <axis xyz="0 0 ${-reflect}"/>
    <limit lower="${radians(-180)}" upper="${radians(180)}" effort="0" velocity="${radians(400)}"/>
  </joint>
  <joint name="joint_tool0" type="fixed">
    <parent link="link_7_t"/>
    <child link="link_tool0"/>
    <origin xyz="0 0 0" rpy="0 0 ${radians(180)}"/>
  </joint>
  <!-- end of joint list -->
</robot>
