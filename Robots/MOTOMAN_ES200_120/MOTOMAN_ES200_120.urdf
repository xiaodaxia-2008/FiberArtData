<?xml version="1.0" encoding="utf-8"?>
<robot name="MOTOMAN_ES200_120">
  <material name="black">
    <color rgba="0.7 0.7 0.7 1.0"/>
  </material>
  <material name="blue">
    <color rgba="0.7 0.7 0.7 1.0"/>
  </material>
  <material name="yellow">
    <color rgba="0.7 0.7 0.7 1.0"/>
  </material>
  <!-- link list -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="visual/base_link.stl"/>
      </geometry>
      <material name="blue">
        <color rgba="0 0 1 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <mesh filename="collision/base_link.stl"/>
      </geometry>
      <material name="yellow">
        <color rgba="0 1 1 1"/>
      </material>
    </collision>
  </link>
  <link name="link_s">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="visual/link_s.stl"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="collision/link_s.stl"/>
      </geometry>
      <material name="yellow"/>
    </collision>
  </link>
  <link name="link_l">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="visual/link_l.stl"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="collision/link_l.stl"/>
      </geometry>
      <material name="yellow"/>
    </collision>
  </link>
  <link name="link_u">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="visual/link_u.stl"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="collision/link_u.stl"/>
      </geometry>
      <material name="yellow"/>
    </collision>
  </link>
  <link name="link_r">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="visual/link_r.stl"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="collision/link_r.stl"/>
      </geometry>
      <material name="yellow"/>
    </collision>
  </link>
  <link name="link_b">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="visual/link_b.stl"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="collision/link_b.stl"/>
      </geometry>
      <material name="yellow"/>
    </collision>
  </link>
  <link name="link_t">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="visual/link_t.stl"/>
      </geometry>
      <material name="black">
        <color rgba="0 0 0 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="collision/link_t.stl"/>
      </geometry>
      <material name="black"/>
    </collision>
  </link>
  <link name="tool0"/>
  <!--

      Balancer and rod are disabled as without a mimic joint they will not update
      their pose properly, leading to MoveIt detecting collisions which cannot
      happen with the real robot (as the balancer is essentially a passive element
      and cannot come into collision with anything due to joint limits).

    <link name="balancer_piston">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://motoman_es_support/meshes/es/visual/balancer_piston.stl"/>
        </geometry>
        <material name="blue"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://motoman_es_support/meshes/es/collision/balancer_piston.stl"/>
        </geometry>
        <material name="yellow"/>
      </collision>
    </link>
    <link name="balancer_rod">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://motoman_es_support/meshes/es/visual/balancer_rod.stl"/>
        </geometry>
        <material name="blue"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://motoman_es_support/meshes/es/collision/balancer_rod.stl"/>
        </geometry>
        <material name="yellow"/>
      </collision>
    </link>
    -->
  <!-- end of link list -->
  <!-- joint list -->
  <property name="velocities" value="${xacro.load_yaml(joint_velocities_file)}"/>
  <joint name="joint_1_s" type="revolute">
    <origin xyz="0 0 0.450" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="link_s"/>
    <axis xyz="0 0 1"/>
    <limit lower="${radians(-180)}" upper="${radians(180)}" effort="0" velocity="${radians(velocities['joint_1_s'])}"/>
  </joint>
  <joint name="joint_2_l" type="revolute">
    <origin xyz="0.740 0 0" rpy="0 0 0"/>
    <parent link="link_s"/>
    <child link="link_l"/>
    <axis xyz="0 1 0"/>
    <limit lower="${radians(-130)}" upper="${radians(80)}" effort="0" velocity="${radians(velocities['joint_2_l'])}"/>
  </joint>
  <joint name="joint_3_u" type="revolute">
    <origin xyz="1.150 0 0" rpy="0 0 0"/>
    <parent link="link_l"/>
    <child link="link_u"/>
    <axis xyz="0 -1 0"/>
    <limit lower="${radians(-107)}" upper="${radians(190)}" effort="0" velocity="${radians(velocities['joint_3_u'])}"/>
  </joint>
  <joint name="joint_4_r" type="revolute">
    <origin xyz="0.250 0 0" rpy="0 0 0"/>
    <parent link="link_u"/>
    <child link="link_r"/>
    <axis xyz="0 0 1"/>
    <limit lower="${radians(-360)}" upper="${radians(360)}" effort="0" velocity="${radians(velocities['joint_4_r'])}"/>
  </joint>
  <joint name="joint_5_b" type="revolute">
    <origin xyz="0 0 -2.100" rpy="0 0 0"/>
    <parent link="link_r"/>
    <child link="link_b"/>
    <axis xyz="0 -1 0"/>
    <limit lower="${radians(-130)}" upper="${radians(130)}" effort="0" velocity="${radians(velocities['joint_5_b'])}"/>
  </joint>
  <joint name="joint_6_t" type="revolute">
    <origin xyz="0 0 -0.225" rpy="0 0 0"/>
    <parent link="link_b"/>
    <child link="link_t"/>
    <axis xyz="0 0 1"/>
    <limit lower="${radians(-360)}" upper="${radians(360)}" effort="0" velocity="${radians(velocities['joint_6_t'])}"/>
  </joint>
  <joint name="joint_t-tool0" type="fixed">
    <origin xyz="0 0 0" rpy="0 ${radians(180)} 0"/>
    <parent link="link_t"/>
    <child link="tool0"/>
  </joint>
  <!--

      See earlier comment about balancer and piston.

    <joint name="joint_balancer_piston" type="fixed">
      <origin xyz="-0.260 0 0.320" rpy="0 0 0"/>
      <parent link="link_s"/>
      <child link="balancer_piston"/>
    </joint>
    <joint name="joint_balancer_rod" type="fixed">
      <origin xyz="${0.740 + 0.220 * cos(radians(55))} 0 ${0.220 * sin(radians(55))}" rpy="0 0 0"/>
      <parent link="link_s"/>
      <child link="balancer_rod"/>
    </joint>
    -->
  <!-- end of joint list -->
  <!-- ROS base_link to Robot Manufacturer World Coordinates transform -->
  <link name="base"/>
  <joint name="base_link-base" type="fixed">
    <origin xyz="0 0 0.450" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="base"/>
  </joint>
</robot>
