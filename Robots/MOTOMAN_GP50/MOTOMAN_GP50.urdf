<?xml version="1.0" encoding="utf-8"?>
<robot name="MOTOMAN_GP50">
  <material name="yaskawa_blue">
    <color rgba="0.7 0.7 0.7 1.0"/>
  </material>
  <!-- link list -->
  <link name="base_link">
    <visual>
      <geometry>
        <mesh filename="visual/base_link.stl"/>
      </geometry>
      <material name="yaskawa_blue"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="collision/base_link.stl"/>
      </geometry>
    </collision>
  </link>
  <link name="link_1_s">
    <visual>
      <geometry>
        <mesh filename="visual/link_1_s.stl"/>
      </geometry>
      <material name="yaskawa_blue"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="collision/link_1_s.stl"/>
      </geometry>
    </collision>
  </link>
  <link name="link_2_l">
    <visual>
      <geometry>
        <mesh filename="visual/link_2_l.stl"/>
      </geometry>
      <material name="yaskawa_blue"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="collision/link_2_l.stl"/>
      </geometry>
    </collision>
  </link>
  <link name="link_3_u">
    <visual>
      <geometry>
        <mesh filename="visual/link_3_u.stl"/>
      </geometry>
      <material name="yaskawa_blue"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="collision/link_3_u.stl"/>
      </geometry>
    </collision>
  </link>
  <link name="link_4_r">
    <visual>
      <geometry>
        <mesh filename="visual/link_4_r.stl"/>
      </geometry>
      <material name="yaskawa_blue"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="collision/link_4_r.stl"/>
      </geometry>
    </collision>
  </link>
  <link name="link_5_b">
    <visual>
      <geometry>
        <mesh filename="visual/link_5_b.stl"/>
      </geometry>
      <material name="yaskawa_blue"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="collision/link_5_b.stl"/>
      </geometry>
    </collision>
  </link>
  <link name="link_6_t">
    <visual>
      <geometry>
        <mesh filename="visual/link_6_t.stl"/>
      </geometry>
      <material name="yaskawa_blue"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="collision/link_6_t.stl"/>
      </geometry>
    </collision>
  </link>
  <link name="tool0"/>
  <!-- end of link list -->
  <!-- joint list -->
  <joint name="joint_1_s" type="revolute">
    <parent link="base_link"/>
    <child link="link_1_s"/>
    <origin xyz="0 0 0.540" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="${radians(-180)}" upper="${radians(180)}" effort="5516" velocity="${radians(180)}"/>
  </joint>
  <joint name="joint_2_l" type="revolute">
    <parent link="link_1_s"/>
    <child link="link_2_l"/>
    <origin xyz="0.145 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="${radians(-90)}" upper="${radians(135)}" effort="7060" velocity="${radians(178)}"/>
  </joint>
  <joint name="joint_3_u" type="revolute">
    <parent link="link_2_l"/>
    <child link="link_3_u"/>
    <origin xyz="0 0 0.870" rpy="0 0 0"/>
    <axis xyz="0 -1 0"/>
    <limit lower="${radians(-80)}" upper="${radians(206)}" effort="3089" velocity="${radians(178)}"/>
  </joint>
  <joint name="joint_4_r" type="revolute">
    <parent link="link_3_u"/>
    <child link="link_4_r"/>
    <origin xyz="0 0 0.210" rpy="0 0 0"/>
    <axis xyz="-1 0 0"/>
    <limit lower="${radians(-360)}" upper="${radians(360)}" effort="926" velocity="${radians(250)}"/>
  </joint>
  <joint name="joint_5_b" type="revolute">
    <parent link="link_4_r"/>
    <child link="link_5_b"/>
    <origin xyz="1.025 0 0" rpy="0 0 0"/>
    <axis xyz="0 -1 0"/>
    <limit lower="${radians(-125)}" upper="${radians(125)}" effort="794" velocity="${radians(250)}"/>
  </joint>
  <joint name="joint_6_t" type="revolute">
    <parent link="link_5_b"/>
    <child link="link_6_t"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="-1 0 0"/>
    <limit lower="${radians(-360)}" upper="${radians(360)}" effort="375" velocity="${radians(360)}"/>
  </joint>
  <joint name="joint_6_t-tool0" type="fixed">
    <origin xyz="0.175 0 0" rpy="3.1415926 -1.570796 0"/>
    <parent link="link_6_t"/>
    <child link="tool0"/>
  </joint>
  <!-- end of joint list -->
  <!-- ROS base_link to Robot Manufacturer World Coordinates transform -->
  <link name="base"/>
  <joint name="base_link-base" type="fixed">
    <origin xyz="0 0 0.540" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="base"/>
  </joint>
</robot>
