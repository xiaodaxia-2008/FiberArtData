<?xml version='1.0' encoding='utf-8'?>
<robot name="MOTOMAN_GP8L" brand="MOTOMAN" type="Robot" payload="8" reach="1.236">
  <material name="yaskawa_blue">
    <color rgba="0.1294118 0.1490196 0.7490196 1.0"/>
  </material>
  <!-- link list -->
  <link name="base_link">
    <visual>
      <geometry>
        <mesh filename="visual/base_link.dae"/>
      </geometry>
      <material name="yaskawa_blue"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="collision/base_link.stl"/>
      </geometry>
    </collision>
  </link>
  <link name="link_1_s">
    <visual>
      <geometry>
        <mesh filename="visual/link_1_s.dae"/>
      </geometry>
      <material name="yaskawa_blue"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="collision/link_1_s.stl"/>
      </geometry>
    </collision>
  </link>
  <link name="link_2_l">
    <visual>
      <geometry>
        <mesh filename="visual/link_2_l.dae"/>
      </geometry>
      <material name="yaskawa_blue"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="collision/link_2_l.stl"/>
      </geometry>
    </collision>
  </link>
  <link name="link_3_u">
    <visual>
      <geometry>
        <mesh filename="visual/link_3_u.dae"/>
      </geometry>
      <material name="yaskawa_blue"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="collision/link_3_u.stl"/>
      </geometry>
    </collision>
  </link>
  <link name="link_4_r">
    <visual>
      <geometry>
        <mesh filename="visual/link_4_r.dae"/>
      </geometry>
      <material name="yaskawa_blue"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="collision/link_4_r.stl"/>
      </geometry>
    </collision>
  </link>
  <link name="link_5_b">
    <visual>
      <geometry>
        <mesh filename="visual/link_5_b.dae"/>
      </geometry>
      <material name="yaskawa_blue"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="collision/link_5_b.stl"/>
      </geometry>
    </collision>
  </link>
  <link name="link_6_t">
    <visual>
      <geometry>
        <mesh filename="visual/link_6_t.dae"/>
      </geometry>
      <material name="yaskawa_blue"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="collision/link_6_t.stl"/>
      </geometry>
    </collision>
  </link>
  <!-- end of link list -->
  <!-- joint list -->
  <joint name="joint_1_s" type="revolute">
    <parent link="base_link"/>
    <child link="link_1_s"/>
    <origin xyz="0 0 0.450" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="${radians(-170)}" upper="${radians(170)}" effort="926.1" velocity="${radians(260)}"/>
  </joint>
  <joint name="joint_2_l" type="revolute">
    <parent link="link_1_s"/>
    <child link="link_2_l"/>
    <origin xyz="0.155 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="${radians(-90)}" upper="${radians(155)}" effort="1029" velocity="${radians(230)}"/>
  </joint>
  <joint name="joint_3_u" type="revolute">
    <parent link="link_2_l"/>
    <child link="link_3_u"/>
    <origin xyz="0 0 0.714" rpy="0 0 0"/>
    <axis xyz="0 -1 0"/>
    <limit lower="${radians(-85)}" upper="${radians(150)}" effort="551.2" velocity="${radians(260)}"/>
  </joint>
  <joint name="joint_4_r" type="revolute">
    <parent link="link_3_u"/>
    <child link="link_4_r"/>
    <origin xyz="0.740 0 0.200" rpy="0 0 0"/>
    <axis xyz="-1 0 0"/>
    <limit lower="${radians(-200)}" upper="${radians(200)}" effort="89.96" velocity="${radians(470)}"/>
  </joint>
  <joint name="joint_5_b" type="revolute">
    <parent link="link_4_r"/>
    <child link="link_5_b"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 -1 0"/>
    <limit lower="${radians(-135)}" upper="${radians(135)}" effort="32.68" velocity="${radians(550)}"/>
  </joint>
  <joint name="joint_6_t" type="revolute">
    <parent link="link_5_b"/>
    <child link="link_6_t"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="-1 0 0"/>
    <limit lower="${radians(-360)}" upper="${radians(360)}" effort="22.54" velocity="${radians(1000)}"/>
  </joint>
  <!-- end of joint list -->
  <!-- ROS-Industrial 'flange' frame: attachment point for EEF models -->
  <link name="flange"/>
  <joint name="joint_6_t-flange" type="fixed">
    <origin xyz="0.080 0 0" rpy="0 0 0"/>
    <parent link="link_6_t"/>
    <child link="flange"/>
  </joint>
  <!-- ROS-Industrial 'tool0' frame: all-zeros tool frame -->
  <link name="tool0"/>
  <joint name="flange-tool0" type="fixed">
    <origin xyz="0 0 0" rpy="${radians(180)} ${radians(-90)} 0"/>
    <parent link="flange"/>
    <child link="tool0"/>
  </joint>
  <!-- ROS base_link to Robot Manufacturer World Coordinates transform -->
  <link name="base"/>
  <joint name="base_link-base" type="fixed">
    <origin xyz="0 0 0.450" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="base"/>
  </joint>
</robot>
