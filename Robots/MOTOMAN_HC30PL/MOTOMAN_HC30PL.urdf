<?xml version='1.0' encoding='utf-8'?>
<robot name="MOTOMAN_HC30PL" brand="MOTOMAN" type="Robot" payload="30" reach="2.1">
  <material name="yaskawa_white">
    <color rgba="0.99 0.99 0.99 1"/>
  </material>
  <!-- link list -->
  <link name="base_link">
    <visual>
      <geometry>
        <mesh filename="visual/base_link.dae"/>
      </geometry>
      <material name="yaskawa_white"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="collision/base_link.stl"/>
      </geometry>
    </collision>
  </link>
  <link name="link_1_s">
    <visual>
      <geometry>
        <mesh filename="visual/link_1_s.dae"/>
      </geometry>
      <material name="yaskawa_white"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="collision/link_1_s.stl"/>
      </geometry>
    </collision>
  </link>
  <link name="link_2_l">
    <visual>
      <geometry>
        <mesh filename="visual/link_2_l.dae"/>
      </geometry>
      <material name="yaskawa_white"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="collision/link_2_l.stl"/>
      </geometry>
    </collision>
  </link>
  <link name="link_3_u">
    <visual>
      <geometry>
        <mesh filename="visual/link_3_u.dae"/>
      </geometry>
      <material name="yaskawa_white"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="collision/link_3_u.stl"/>
      </geometry>
    </collision>
  </link>
  <link name="link_4_r">
    <visual>
      <geometry>
        <mesh filename="visual/link_4_r.dae"/>
      </geometry>
      <material name="yaskawa_white"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="collision/link_4_r.stl"/>
      </geometry>
    </collision>
  </link>
  <link name="link_5_b">
    <visual>
      <geometry>
        <mesh filename="visual/link_5_b.dae"/>
      </geometry>
      <origin rpy="0 1.57075 0"/>
      <material name="yaskawa_white"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="collision/link_5_b.stl"/>
      </geometry>
      <origin rpy="0 1.57075 0"/>
    </collision>
  </link>
  <link name="link_6_t">
    <visual>
      <geometry>
        <mesh filename="visual/link_6_t.dae"/>
      </geometry>
      <origin rpy="0 1.57075 0"/>
      <material name="yaskawa_white"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="collision/link_6_t.stl"/>
      </geometry>
      <origin rpy="0 1.57075 0"/>
    </collision>
  </link>
  <!-- end of link list -->
  <!-- joint list -->
  <joint name="joint_1_s" type="revolute">
    <parent link="base_link"/>
    <child link="link_1_s"/>
    <origin xyz="0 0 0.380" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="${radians(-210)}" upper="${radians(210)}" effort="917.28" velocity="${radians(80)}"/>
  </joint>
  <joint name="joint_2_l" type="revolute">
    <parent link="link_1_s"/>
    <child link="link_2_l"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="${radians(-180)}" upper="${radians(180)}" effort="1223.04" velocity="${radians(80)}"/>
  </joint>
  <joint name="joint_3_u" type="revolute">
    <parent link="link_2_l"/>
    <child link="link_3_u"/>
    <origin xyz="0 0 0.820" rpy="0 0 0"/>
    <axis xyz="0 -1 0"/>
    <limit lower="${radians(-67)}" upper="${radians(247)}" effort="642.88" velocity="${radians(120)}"/>
  </joint>
  <joint name="joint_4_r" type="revolute">
    <parent link="link_3_u"/>
    <child link="link_4_r"/>
    <origin xyz="0.880 0 0" rpy="0 0 0"/>
    <axis xyz="-1 0 0"/>
    <!-- see note in package.xml regarding joint position limits -->
    <limit lower="${radians(-210)}" upper="${radians(210)}" effort="368.48" velocity="${radians(130)}"/>
  </joint>
  <joint name="joint_5_b" type="revolute">
    <parent link="link_4_r"/>
    <child link="link_5_b"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 -1 0"/>
    <!-- see note in package.xml regarding joint position limits -->
    <limit lower="${radians(-90)}" upper="${radians(270)}" effort="141.12" velocity="${radians(180)}"/>
  </joint>
  <joint name="joint_6_t" type="revolute">
    <parent link="link_5_b"/>
    <child link="link_6_t"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="${radians(-210)}" upper="${radians(210)}" effort="141.12" velocity="${radians(180)}"/>
  </joint>
  <!-- end of joint list -->
  <!-- ROS-Industrial 'flange' frame: attachment point for EEF models -->
  <link name="flange"/>
  <joint name="joint_6_t-flange" type="fixed">
    <origin xyz="0 0 -0.200" rpy="0 0 0"/>
    <parent link="link_6_t"/>
    <child link="flange"/>
  </joint>
  <!-- ROS-Industrial 'tool0' frame: all-zeros tool frame -->
  <link name="tool0"/>
  <joint name="flange-tool0" type="fixed">
    <origin xyz="0 0 0" rpy="0 ${radians(180)} ${radians(180)}"/>
    <parent link="flange"/>
    <child link="tool0"/>
  </joint>
  <!-- ROS base_link to Robot Manufacturer World Coordinates transform -->
  <link name="base"/>
  <joint name="base_link-base" type="fixed">
    <origin xyz="0 0 0.380" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="base"/>
  </joint>
</robot>
