<?xml version="1.0" encoding="utf-8"?>
<robot name="MOTOMAN_MH5L" payload="5" reach="0.895" brand="MOTOMAN" type="Robot">
  <material name="yaskawa_white">
    <color rgba="0.99 0.99 0.99 1"/>
  </material>
  <!-- link list -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="visual/base_link.stl"/>
      </geometry>
      <material name="yaskawa_white"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="collision/base_link.stl"/>
      </geometry>
    </collision>
  </link>
  <link name="link_1_s">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="visual/link_1_s.stl"/>
      </geometry>
      <material name="yaskawa_white"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="collision/link_1_s.stl"/>
      </geometry>
    </collision>
  </link>
  <link name="link_2_l">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="visual/link_2_l.stl"/>
      </geometry>
      <material name="yaskawa_white"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="collision/link_2_l.stl"/>
      </geometry>
    </collision>
  </link>
  <link name="link_3_u">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="visual/link_3_u.stl"/>
      </geometry>
      <material name="yaskawa_white"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="collision/link_3_u.stl"/>
      </geometry>
    </collision>
  </link>
  <link name="link_4_r">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="visual/link_4_r.stl"/>
      </geometry>
      <material name="yaskawa_white"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="collision/link_4_r.stl"/>
      </geometry>
    </collision>
  </link>
  <link name="link_5_b">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="visual/link_5_b.stl"/>
      </geometry>
      <material name="yaskawa_white"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="collision/link_5_b.stl"/>
      </geometry>
    </collision>
  </link>
  <link name="link_6_t">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="visual/link_6_t.stl"/>
      </geometry>
      <material name="yaskawa_white"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="collision/link_6_t.stl"/>
      </geometry>
    </collision>
  </link>
  <!-- end of link list -->
  <!-- joint list -->
  <joint name="joint_1_s" type="revolute">
    <parent link="base_link"/>
    <child link="link_1_s"/>
    <origin xyz="0 0 0.330" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-${radians(170)}" upper="${radians(170)}" effort="303.8" velocity="${radians(270)}"/>
  </joint>
  <joint name="joint_2_l" type="revolute">
    <parent link="link_1_s"/>
    <child link="link_2_l"/>
    <origin xyz="0.0880 0 0.00" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-${radians(65)}" upper="${radians(150)}" effort="205.8" velocity="${radians(280)}"/>
  </joint>
  <joint name="joint_3_u" type="revolute">
    <parent link="link_2_l"/>
    <child link="link_3_u"/>
    <origin xyz="0 0 0.400" rpy="0 0 0"/>
    <axis xyz="0 -1 0"/>
    <limit lower="-${radians(70)}" upper="${radians(190)}" effort="85.5" velocity="${radians(300)}"/>
  </joint>
  <joint name="joint_4_r" type="revolute">
    <parent link="link_3_u"/>
    <child link="link_4_r"/>
    <origin xyz="0 0 0.040" rpy="0 0 0"/>
    <axis xyz="-1 0 0"/>
    <limit lower="-${radians(190)}" upper="${radians(190)}" effort="44.7" velocity="${radians(450)}"/>
  </joint>
  <joint name="joint_5_b" type="revolute">
    <parent link="link_4_r"/>
    <child link="link_5_b"/>
    <origin xyz="0.405 0 0" rpy="0 0 0"/>
    <axis xyz="0 -1 0"/>
    <limit lower="-${radians(135)}" upper="${radians(135)}" effort="18.0" velocity="${radians(450)}"/>
  </joint>
  <joint name="joint_6_t" type="revolute">
    <parent link="link_5_b"/>
    <child link="link_6_t"/>
    <origin xyz="0.080 0 0" rpy="0 0 0"/>
    <axis xyz="-1 0 0"/>
    <limit lower="-${radians(360)}" upper="${radians(360)}" effort="18.0" velocity="${radians(720)}"/>
  </joint>
  <!-- end of joint list -->
  <!-- ROS base_link to Robot Manufacturer (Motoman) World Coordinates transform -->
  <link name="base"/>
  <joint name="base_link-base" type="fixed">
    <parent link="base_link"/>
    <child link="base"/>
    <origin xyz="0 0 0.330" rpy="0 0 0"/>
  </joint>
  <!-- ROS-Industrial 'flange' frame: attachment point for EEF models -->
  <link name="flange"/>
  <joint name="joint_6_t-flange" type="fixed">
    <parent link="link_6_t"/>
    <child link="flange"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>
  <!-- ROS-Industrial 'tool0' frame: all-zeros tool frame -->
  <link name="tool0"/>
  <joint name="joint_6_t-tool0" type="fixed">
    <parent link="link_6_t"/>
    <child link="tool0"/>
    <origin xyz="0 0 0" rpy="${radians(180)} ${radians(-90)} 0"/>
  </joint>
</robot>
