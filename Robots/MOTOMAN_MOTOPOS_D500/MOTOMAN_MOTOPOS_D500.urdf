<?xml version="1.0" encoding="utf-8"?>
<robot name="MOTOMAN_MOTOPOS_D500" brand="MOTOMAN" type="Robot">
  <material name="yaskawa_blue">
    <color rgba="0.1294118 0.1490196 0.7490196 1.0"/>
  </material>
  <!-- link list -->
  <link name="base_link">
    <visual>
      <geometry>
        <mesh filename="visual/base_link.stl"/>
      </geometry>
      <material name="yaskawa_blue"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="collision/base_link.stl"/>
      </geometry>
    </collision>
  </link>
  <link name="link_1">
    <visual>
      <geometry>
        <mesh filename="visual/link_1.stl"/>
      </geometry>
      <material name="yaskawa_blue"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="collision/link_1.stl"/>
      </geometry>
    </collision>
  </link>
  <link name="link_2">
    <visual>
      <geometry>
        <mesh filename="visual/link_2.stl"/>
      </geometry>
      <material name="yaskawa_blue"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="collision/link_2.stl"/>
      </geometry>
    </collision>
  </link>
  <!-- end of link list -->
  <!-- joint list -->
  <joint name="joint_1" type="revolute">
    <parent link="base_link"/>
    <child link="link_1"/>
    <origin xyz="0 0 0.380" rpy="0 0 0"/>
    <axis xyz="0 -1 0"/>
    <limit lower="-2.3561" upper="2.3561" effort="1274" velocity="1.3962"/>
  </joint>
  <joint name="joint_2" type="revolute">
    <parent link="link_1"/>
    <child link="link_2"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 -1"/>
    <limit lower="-3.4906" upper="3.4906" effort="392" velocity="2.7925"/>
  </joint>
  <!-- end of joint list -->
  <!-- ROS base_link to Robot Manufacturer World Coordinates transform -->
  <link name="base"/>
  <joint name="base_link-base" type="fixed">
    <origin xyz="0 0 0.380" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="base"/>
  </joint>
  <!-- ROS-Industrial 'tool0' frame: all-zeros tool frame -->
  <link name="tool0"/>
  <joint name="joint_2-tool0" type="fixed">
    <origin xyz="0 0 0.150 " rpy="0 0 0"/>
    <parent link="link_2"/>
    <child link="tool0"/>
  </joint>
</robot>
