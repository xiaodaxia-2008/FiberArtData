<?xml version="1.0" encoding="utf-8"?>
<robot name="MOTOMAN_MPX1950" brand="MOTOMAN" type="Robot">
  <material name="yaskawa_blue">
    <color rgba="0.1294118 0.1490196 0.7490196 1.0"/>
  </material>
  <material name="yaskawa_silver">
    <color rgba="0.8 0.8 0.8 1"/>
  </material>
  <!-- link list -->
  <link name="base_link">
    <visual>
      <geometry>
        <mesh filename="visual/base_link.dae"/>
      </geometry>
      <material name="yaskawa_blue"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="collision/base_link.stl"/>
      </geometry>
    </collision>
  </link>
  <link name="link_1_s">
    <visual>
      <geometry>
        <mesh filename="visual/link_1_s.dae"/>
      </geometry>
      <material name="yaskawa_blue"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="collision/link_1_s.stl"/>
      </geometry>
    </collision>
  </link>
  <link name="link_2_l">
    <visual>
      <geometry>
        <mesh filename="visual/link_2_l.dae"/>
      </geometry>
      <material name="yaskawa_blue"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="collision/link_2_l.stl"/>
      </geometry>
    </collision>
  </link>
  <link name="link_3_u">
    <visual>
      <geometry>
        <mesh filename="visual/link_3_u.dae"/>
      </geometry>
      <material name="yaskawa_blue"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="collision/link_3_u.stl"/>
      </geometry>
    </collision>
  </link>
  <link name="link_4_r">
    <visual>
      <geometry>
        <mesh filename="visual/link_4_r.dae"/>
      </geometry>
      <material name="yaskawa_blue"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="collision/link_4_r.stl"/>
      </geometry>
    </collision>
  </link>
  <link name="link_5_b">
    <visual>
      <geometry>
        <mesh filename="visual/link_5_b.dae"/>
      </geometry>
      <material name="yaskawa_blue"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="collision/link_5_b.stl"/>
      </geometry>
    </collision>
  </link>
  <link name="link_6_t">
    <visual>
      <geometry>
        <mesh filename="visual/link_6_t.dae"/>
      </geometry>
      <material name="yaskawa_silver"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="collision/link_6_t.stl"/>
      </geometry>
    </collision>
  </link>
  <!-- end of link list -->
  <!-- joint list -->
  <joint name="joint_1_s" type="revolute">
    <parent link="base_link"/>
    <child link="link_1_s"/>
    <origin xyz="0 0 0.500" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="${radians(-170)}" upper="${radians(170)}" effort="2940" velocity="${radians(180.4)}"/>
  </joint>
  <joint name="joint_2_l" type="revolute">
    <parent link="link_1_s"/>
    <child link="link_2_l"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="${radians(-100)}" upper="${radians(140)}" effort="2940" velocity="${radians(180.4)}"/>
  </joint>
  <joint name="joint_3_u" type="revolute">
    <parent link="link_2_l"/>
    <child link="link_3_u"/>
    <origin xyz="0 0 0.725" rpy="0 0 0"/>
    <axis xyz="0 -1 0"/>
    <limit lower="${radians(-62)}" upper="${radians(235)}" effort="1470" velocity="${radians(180.2)}"/>
  </joint>
  <joint name="joint_4_r" type="revolute">
    <parent link="link_3_u"/>
    <child link="link_4_r"/>
    <origin xyz="0.725 0 0.015" rpy="0 0 0"/>
    <axis xyz="-1 0 0"/>
    <limit lower="${radians(-200)}" upper="${radians(200)}" effort="215.6" velocity="${radians(360)}"/>
  </joint>
  <joint name="joint_5_b" type="revolute">
    <parent link="link_4_r"/>
    <child link="link_5_b"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 -1 0"/>
    <limit lower="${radians(-150)}" upper="${radians(150)}" effort="96.04" velocity="${radians(400)}"/>
  </joint>
  <joint name="joint_6_t" type="revolute">
    <parent link="link_5_b"/>
    <child link="link_6_t"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="-1 0 0"/>
    <limit lower="${radians(-400)}" upper="${radians(400)}" effort="22.54" velocity="${radians(500)}"/>
  </joint>
  <!-- end of joint list -->
  <!-- ROS-Industrial 'flange' frame: attachment point for EEF models -->
  <link name="flange"/>
  <joint name="joint_6_t-flange" type="fixed">
    <origin xyz="0.100 0 0" rpy="0 0 0"/>
    <parent link="link_6_t"/>
    <child link="flange"/>
  </joint>
  <!-- ROS-Industrial 'tool0' frame: all-zeros tool frame -->
  <link name="tool0"/>
  <joint name="flange-tool0" type="fixed">
    <origin xyz="0 0 0" rpy="${radians(180)} ${radians(-90)} 0"/>
    <parent link="flange"/>
    <child link="tool0"/>
  </joint>
  <!-- ROS base_link to Robot Manufacturer World Coordinates transform -->
  <link name="base"/>
  <joint name="base_link-base" type="fixed">
    <origin xyz="0 0 0.500" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="base"/>
  </joint>
</robot>
