<?xml version="1.0" encoding="utf-8"?>
<robot name="MOTOMAN_SIA10F" brand="MOTOMAN" type="Robot">
  <material name="yaskawa_blue">
    <color rgba="0.1294118 0.1490196 0.7490196 1.0"/>
  </material>
  <material name="yaskawa_white">
    <color rgba="0.99 0.99 0.99 1"/>
  </material>
  <material name="yellow">
    <color rgba="0 1 1 1"/>
  </material>
  <!-- link list -->
  <link name="base_link">
    <visual>
      <geometry>
        <mesh filename="visual/motoman_base.stl"/>
      </geometry>
      <material name="yaskawa_blue"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="collision/motoman_base.stl"/>
      </geometry>
      <material name="yellow">
        <color rgba="0 1 1 1"/>
      </material>
    </collision>
  </link>
  <link name="link_1_s">
    <visual>
      <geometry>
        <mesh filename="visual/motoman_axis_s.stl"/>
      </geometry>
      <material name="yaskawa_white"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="collision/motoman_axis_s.stl"/>
      </geometry>
      <material name="yellow"/>
    </collision>
  </link>
  <link name="link_2_l">
    <visual>
      <origin rpy="1.57 3.1416 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="visual/motoman_axis_l.stl"/>
      </geometry>
      <material name="yaskawa_blue"/>
    </visual>
    <collision>
      <origin rpy="1.57 3.1416 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="collision/motoman_axis_l.stl"/>
      </geometry>
      <material name="yellow"/>
    </collision>
  </link>
  <link name="link_3_e">
    <visual>
      <origin rpy="0 0 3.1415" xyz="0 0 0"/>
      <geometry>
        <mesh filename="visual/motoman_axis_e.stl"/>
      </geometry>
      <material name="yaskawa_white"/>
    </visual>
    <collision>
      <origin rpy="0 0 3.1415" xyz="0 0 0"/>
      <geometry>
        <mesh filename="collision/motoman_axis_e.stl"/>
      </geometry>
      <material name="yellow"/>
    </collision>
  </link>
  <link name="link_4_u">
    <visual>
      <origin rpy="1.57 -3.1415 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="visual/motoman_axis_u.stl"/>
      </geometry>
      <material name="yaskawa_blue"/>
    </visual>
    <collision>
      <origin rpy="1.57 -3.1415 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="collision/motoman_axis_u.stl"/>
      </geometry>
      <material name="yellow"/>
    </collision>
  </link>
  <link name="link_5_r">
    <visual>
      <origin rpy="0 0 3.1416" xyz="0 0 0"/>
      <geometry>
        <mesh filename="visual/motoman_axis_r.stl"/>
      </geometry>
      <material name="yaskawa_white"/>
    </visual>
    <collision>
      <origin rpy="0 0 3.1416" xyz="0 0 0"/>
      <geometry>
        <mesh filename="collision/motoman_axis_r.stl"/>
      </geometry>
      <material name="yellow"/>
    </collision>
  </link>
  <link name="link_6_b">
    <visual>
      <origin rpy="-1.57 0 3.1416" xyz="0 0 0"/>
      <geometry>
        <mesh filename="visual/motoman_axis_b.stl"/>
      </geometry>
      <material name="yaskawa_blue"/>
    </visual>
    <collision>
      <origin rpy="-1.57 0 3.1416" xyz="0 0 0"/>
      <geometry>
        <mesh filename="collision/motoman_axis_b.stl"/>
      </geometry>
      <material name="yellow"/>
    </collision>
  </link>
  <link name="link_7_t">
    <visual>
      <geometry>
        <mesh filename="visual/motoman_axis_t.stl"/>
      </geometry>
      <material name="yaskawa_white"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="collision/motoman_axis_t.stl"/>
      </geometry>
      <material name="yellow"/>
    </collision>
  </link>
  <link name="link_tool0"/>
  <!-- end of link list -->
  <!-- joint list -->
  <joint name="joint_1_s" type="revolute">
    <parent link="base_link"/>
    <child link="link_1_s"/>
    <origin xyz="0 0 0.36" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.1415" upper="3.1415" effort="0" velocity="2.9670"/>
  </joint>
  <joint name="joint_2_l" type="revolute">
    <parent link="link_1_s"/>
    <child link="link_2_l"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.9198" upper="1.9198" effort="0" velocity="2.9670"/>
  </joint>
  <joint name="joint_3_e" type="revolute">
    <parent link="link_2_l"/>
    <child link="link_3_e"/>
    <origin xyz="0 0 0.36" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.9670" upper="2.9670" effort="0" velocity="2.9670"/>
  </joint>
  <joint name="joint_4_u" type="revolute">
    <parent link="link_3_e"/>
    <child link="link_4_u"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 -1 0"/>
    <limit lower="-2.3561" upper="2.3561" effort="0" velocity="2.9670"/>
  </joint>
  <joint name="joint_5_r" type="revolute">
    <parent link="link_4_u"/>
    <child link="link_5_r"/>
    <origin xyz="0 0 0.360" rpy="0 0 0"/>
    <axis xyz="0 0 -1"/>
    <limit lower="-3.1415" upper="3.1415" effort="0" velocity="3.4906"/>
  </joint>
  <joint name="joint_6_b" type="revolute">
    <parent link="link_5_r"/>
    <child link="link_6_b"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 -1 0"/>
    <limit lower="-1.9198" upper="1.9198" effort="0" velocity="3.4906"/>
  </joint>
  <joint name="joint_7_t" type="revolute">
    <parent link="link_6_b"/>
    <child link="link_7_t"/>
    <origin xyz="0 0 0.155" rpy="0 0 0"/>
    <axis xyz="0 0 -1"/>
    <limit lower="-3.1415" upper="3.1415" effort="0" velocity="6.9813"/>
  </joint>
  <joint name="joint_tool0" type="fixed">
    <origin xyz="0 0 0.0" rpy="0 0 -3.1415926535"/>
    <parent link="link_7_t"/>
    <child link="link_tool0"/>
  </joint>
  <!-- end of joint list -->
  <!-- ROS base_link (via base_link) to Motoman Robot (not Base) Frame transform -->
  <link name="base"/>
  <joint name="base_link-base" type="fixed">
    <origin xyz="0 0 0.360" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="base"/>
  </joint>
</robot>
