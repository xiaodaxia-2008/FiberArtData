<?xml version="1.0" encoding="utf-8"?>
<robot name="MOTOMAN_SIA20D" payload="20" reach="1.3" brand="MOTOMAN" type="Robot">
  <material name="yaskawa_blue">
    <color rgba="0.1294118 0.1490196 0.7490196 1.0"/>
  </material>
  <material name="yaskawa_white">
    <color rgba="0.99 0.99 0.99 1"/>
  </material>
  <material name="yaskawa_yellow">
    <color rgba="0 1 1 1"/>
  </material>
  <!-- link list -->
  <link name="base_link">
    <visual>
      <geometry>
        <mesh filename="visual/MOTOMAN_BASE.stl"/>
      </geometry>
      <material name="yaskawa_blue"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="collision/MOTOMAN_BASE.stl"/>
      </geometry>
      <material name="yaskawa_yellow"/>
    </collision>
  </link>
  <link name="link_s">
    <visual>
      <origin rpy="0 0 3.1416" xyz="0 0 0"/>
      <geometry>
        <mesh filename="visual/MOTOMAN_AXIS_S.stl"/>
      </geometry>
      <material name="yaskawa_white"/>
    </visual>
    <collision>
      <origin rpy="0 0 3.1416" xyz="0 0 0"/>
      <geometry>
        <mesh filename="collision/MOTOMAN_AXIS_S.stl"/>
      </geometry>
      <material name="yaskawa_yellow"/>
    </collision>
  </link>
  <link name="link_l">
    <visual>
      <origin rpy="1.57 3.1416 3.1416" xyz="0 0 0"/>
      <geometry>
        <mesh filename="visual/MOTOMAN_AXIS_L.stl"/>
      </geometry>
      <material name="yaskawa_blue"/>
    </visual>
    <collision>
      <origin rpy="1.57 3.1416 3.1416" xyz="0 0 0"/>
      <geometry>
        <mesh filename="collision/MOTOMAN_AXIS_L.stl"/>
      </geometry>
      <material name="yaskawa_yellow"/>
    </collision>
  </link>
  <link name="link_e">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="visual/MOTOMAN_AXIS_E.stl"/>
      </geometry>
      <material name="yaskawa_white"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="collision/MOTOMAN_AXIS_E.stl"/>
      </geometry>
      <material name="yaskawa_yellow"/>
    </collision>
  </link>
  <link name="link_u">
    <visual>
      <origin rpy="1.57 -3.1415 3.1416" xyz="0 0 0"/>
      <geometry>
        <mesh filename="visual/MOTOMAN_AXIS_U.stl"/>
      </geometry>
      <material name="yaskawa_blue"/>
    </visual>
    <collision>
      <origin rpy="1.57 -3.1415 3.1416" xyz="0 0 0"/>
      <geometry>
        <mesh filename="collision/MOTOMAN_AXIS_U.stl"/>
      </geometry>
      <material name="yaskawa_yellow"/>
    </collision>
  </link>
  <link name="link_r">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="visual/MOTOMAN_AXIS_R.stl"/>
      </geometry>
      <material name="yaskawa_white"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="collision/MOTOMAN_AXIS_R.stl"/>
      </geometry>
      <material name="yaskawa_yellow"/>
    </collision>
  </link>
  <link name="link_b">
    <visual>
      <origin rpy="-1.57 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="visual/MOTOMAN_AXIS_B.stl"/>
      </geometry>
      <material name="yaskawa_blue"/>
    </visual>
    <collision>
      <origin rpy="-1.57 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="collision/MOTOMAN_AXIS_B.stl"/>
      </geometry>
      <material name="yaskawa_yellow"/>
    </collision>
  </link>
  <link name="link_t">
    <visual>
      <geometry>
        <mesh filename="visual/MOTOMAN_AXIS_T.stl"/>
      </geometry>
      <material name="yaskawa_white"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="collision/MOTOMAN_AXIS_T.stl"/>
      </geometry>
      <material name="yaskawa_yellow"/>
    </collision>
  </link>
  <link name="tool0"/>
  <!-- end of link list -->
  <!-- joint list -->
  <joint name="joint_s" type="revolute">
    <parent link="base_link"/>
    <child link="link_s"/>
    <origin xyz="0 0 0.41" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.1415" upper="3.1415" effort="100" velocity="2.2689"/>
  </joint>
  <joint name="joint_l" type="revolute">
    <parent link="link_s"/>
    <child link="link_l"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.9198" upper="1.9198" effort="100" velocity="2.2689"/>
  </joint>
  <joint name="joint_e" type="revolute">
    <parent link="link_l"/>
    <child link="link_e"/>
    <origin xyz="0 0 0.49" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.9670" upper="2.9670" effort="100" velocity="2.9670"/>
  </joint>
  <joint name="joint_u" type="revolute">
    <parent link="link_e"/>
    <child link="link_u"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 -1 0"/>
    <limit lower="-2.2689" upper="2.2689" effort="100" velocity="2.9670"/>
  </joint>
  <joint name="joint_r" type="revolute">
    <parent link="link_u"/>
    <child link="link_r"/>
    <origin xyz="0 0 0.420" rpy="0 0 0"/>
    <axis xyz="0 0 -1"/>
    <limit lower="-3.1415" upper="3.1415" effort="100" velocity="3.4906"/>
  </joint>
  <joint name="joint_b" type="revolute">
    <parent link="link_r"/>
    <child link="link_b"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 -1 0"/>
    <limit lower="-1.9198" upper="1.9198" effort="100" velocity="3.4906"/>
  </joint>
  <joint name="joint_t" type="revolute">
    <parent link="link_b"/>
    <child link="link_t"/>
    <origin xyz="0 0 0.18" rpy="0 0 0"/>
    <axis xyz="0 0 -1"/>
    <limit lower="-3.1415" upper="3.1415" effort="100" velocity="6.9813"/>
  </joint>
  <joint name="link_t-tool0" type="fixed">
    <origin xyz="0 0 0.0" rpy="0 0 -3.1415926535"/>
    <parent link="link_t"/>
    <child link="tool0"/>
  </joint>
  <!-- end of joint list -->
  <!-- ROS base_link (via base_link) to Motoman Robot (not Base) Frame transform -->
  <link name="base"/>
  <joint name="base_link-base" type="fixed">
    <origin xyz="0 0 0.410" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="base"/>
  </joint>
</robot>
