<?xml version="1.0" encoding="utf-8"?>
<robot name="MOTOMAN_SIA30D" brand="MOTOMAN" type="Robot">
  <material name="yaskawa_blue">
    <color rgba="0.1294118 0.1490196 0.7490196 1.0"/>
  </material>
  <material name="yaskawa_silver">
    <color rgba="0.8 0.8 0.8 1"/>
  </material>
  <!-- link list -->
  <link name="base_link">
    <visual>
      <geometry>
        <mesh filename="visual/base_link.stl"/>
      </geometry>
      <material name="yaskawa_blue"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="collision/base_link.stl"/>
      </geometry>
    </collision>
  </link>
  <link name="link_1_s">
    <visual>
      <geometry>
        <mesh filename="visual/link_1_s.stl"/>
      </geometry>
      <material name="yaskawa_silver"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="collision/link_1_s.stl"/>
      </geometry>
    </collision>
  </link>
  <link name="link_2_l">
    <visual>
      <geometry>
        <mesh filename="visual/link_2_l.stl"/>
      </geometry>
      <material name="yaskawa_blue"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="collision/link_2_l.stl"/>
      </geometry>
    </collision>
  </link>
  <link name="link_3_e">
    <visual>
      <geometry>
        <mesh filename="visual/link_3_e.stl"/>
      </geometry>
      <material name="yaskawa_silver"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="collision/link_3_e.stl"/>
      </geometry>
    </collision>
  </link>
  <link name="link_4_u">
    <visual>
      <geometry>
        <mesh filename="visual/link_4_u.stl"/>
      </geometry>
      <material name="yaskawa_blue"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="collision/link_4_u.stl"/>
      </geometry>
    </collision>
  </link>
  <link name="link_5_r">
    <visual>
      <geometry>
        <mesh filename="visual/link_5_r.stl"/>
      </geometry>
      <material name="yaskawa_silver"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="collision/link_5_r.stl"/>
      </geometry>
    </collision>
  </link>
  <link name="link_6_b">
    <visual>
      <geometry>
        <mesh filename="visual/link_6_b.stl"/>
      </geometry>
      <material name="yaskawa_blue"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="collision/link_6_b.stl"/>
      </geometry>
    </collision>
  </link>
  <link name="link_7_t">
    <visual>
      <geometry>
        <mesh filename="visual/link_7_t.stl"/>
      </geometry>
      <material name="yaskawa_silver"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="collision/link_7_t.stl"/>
      </geometry>
    </collision>
  </link>
  <!-- end of link list -->
  <!-- joint list -->
  <joint name="joint_1_s" type="revolute">
    <parent link="base_link"/>
    <child link="link_1_s"/>
    <origin xyz="0 0 0.598" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="${radians(-180)}" upper="${radians(180)}" effort="1911" velocity="${radians(130)}"/>
  </joint>
  <joint name="joint_2_l" type="revolute">
    <parent link="link_1_s"/>
    <child link="link_2_l"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="${radians(-125)}" upper="${radians(125)}" effort="2388" velocity="${radians(130)}"/>
  </joint>
  <joint name="joint_3_e" type="revolute">
    <parent link="link_2_l"/>
    <child link="link_3_e"/>
    <origin xyz="0 0 0.875" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="${radians(-170)}" upper="${radians(170)}" effort="674" velocity="${radians(130)}"/>
  </joint>
  <joint name="joint_4_u" type="revolute">
    <parent link="link_3_e"/>
    <child link="link_4_u"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 -1 0"/>
    <limit lower="${radians(-110)}" upper="${radians(110)}" effort="674" velocity="${radians(130)}"/>
  </joint>
  <joint name="joint_5_r" type="revolute">
    <parent link="link_4_u"/>
    <child link="link_5_r"/>
    <origin xyz="0 0 0.610" rpy="0 0 0"/>
    <axis xyz="0 0 -1"/>
    <limit lower="${radians(-170)}" upper="${radians(170)}" effort="191" velocity="${radians(170)}"/>
  </joint>
  <joint name="joint_6_b" type="revolute">
    <parent link="link_5_r"/>
    <child link="link_6_b"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 -1 0"/>
    <limit lower="${radians(-110)}" upper="${radians(110)}" effort="191" velocity="${radians(170)}"/>
  </joint>
  <joint name="joint_7_t" type="revolute">
    <parent link="link_6_b"/>
    <child link="link_7_t"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 -1"/>
    <limit lower="${radians(-180)}" upper="${radians(180)}" effort="77" velocity="${radians(200)}"/>
  </joint>
  <!-- end of joint list -->
  <!-- ROS base_link to Robot Manufacturer World Coordinates transform -->
  <link name="base"/>
  <joint name="base_link-base" type="fixed">
    <origin xyz="0 0 0.598" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="base"/>
  </joint>
  <!-- ROS-Industrial 'tool0' frame: all-zeros tool frame -->
  <link name="tool0"/>
  <joint name="link_7_t-tool0" type="fixed">
    <origin xyz="0 0 0.217" rpy="0 0 ${pi}"/>
    <parent link="link_7_t"/>
    <child link="tool0"/>
  </joint>
</robot>
