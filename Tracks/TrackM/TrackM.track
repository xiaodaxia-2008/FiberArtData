<?xml version='1.0' encoding='UTF-8'?>
<robot name="TrackM">
  <!-- Properties -->
  <!-- link list -->
  <material name="gray">
    <color rgba="0.4 0.4 0.4 1"/>
  </material>
  <material name="gray2">
    <color rgba="0.5 0.5 0.5 1"/>
  </material>
  <link name="base_link">
    <visual>
      <geometry>
        <mesh filename="visual/base_link.stl"/>
      </geometry>
      <material name="gray"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="collision/base_link.stl"/>
      </geometry>
    </collision>
  </link>
  <link name="link1">
    <visual>
      <geometry>
        <mesh filename="visual/link1.stl"/>
      </geometry>
      <material name="gray2"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="collision/link1.stl"/>
      </geometry>
    </collision>
  </link>
  <link name="ee_link"/>
  <!-- end of link list -->
  <!-- joint list -->
  <joint name="joint1" type="prismatic">
    <parent link="base_link"/>
    <child link="link1"/>
    <origin xyz="0 -16 0" rpy="0.0 0.0 0.0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.001745" upper="0.279253" velocity="0.017453"/>
  </joint>
  <joint name="joint_1_t-tool0" type="fixed">
    <origin xyz="0 0 0" rpy="0.0 0.0 0.0"/>
    <parent link="link1"/>
    <child link="ee_link"/>
  </joint>
  <!-- end of joint list -->
  <!-- local base r.t. to world frame -->
  <base_pose xyz="0 16 0" rpy="0.0 0.0 0.0"/>
</robot>
